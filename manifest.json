{
  "manifest_version": 3,
  "name": "DepAnalyzer",
  "version": "1.0.0",
  "description": "Detect and categorize website dependencies for internet filter management",
  "permissions": [
    "webRequest",
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "DepAnalyzer"
  },
  "options_page": "options.html"
}
